# Environment variables example for Django Fortress

# DJANGO SETTINGS
DJANGO_ENV=dev
DJANGO_SECRET_KEY=django-insecure-fallback-key-change-me-in-prod
DJANGO_DEBUG=True

# DATABASE (Used if DJANGO_ENV=prod)
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# SECURITY (Used if DJANGO_ENV=prod)
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000
